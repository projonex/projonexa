{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/final-year-projects",
      "destination": "/college-projects",
      "permanent": true
    },
    {
      "source": "/research",
      "destination": "/services",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/college-projects", "destination": "/college-projects/index.html" },
    { "source": "/client-projects", "destination": "/client-projects/index.html" },
    { "source": "/affiliate-program", "destination": "/affiliate-program/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/services", "destination": "/services/index.html" },
    { "source": "/pricing", "destination": "/pricing/index.html" },
    { "source": "/faq", "destination": "/faq/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/projects", "destination": "/projects/index.html" },
    { "source": "/projects/:slug", "destination": "/projects/:slug/index.html" },
    { "source": "/portfolio", "destination": "/portfolio/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/careers", "destination": "/careers/index.html" },
    { "source": "/careers/apply", "destination": "/careers/apply/index.html" },
    { "source": "/inquiry/corporate", "destination": "/inquiry/corporate/index.html" },
    { "source": "/inquiry/students", "destination": "/inquiry/students/index.html" },
    { "source": "/inquiry/affiliate", "destination": "/inquiry/affiliate/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/og/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
