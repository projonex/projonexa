# Projonexa website — copy to .env.local for local overrides (never commit .env.local)
#
# Production URLs and brand config live in src/data/brand.ts.
# Only use NEXT_PUBLIC_* for values that must be read in the browser.

# Backend API (required for form submissions)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional: analytics (when integrated)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=projonexa.com
