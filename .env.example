# Projonexa website — copy to .env.local for local development (never commit .env.local)
#
# Brand URL, SEO, GEO, and AEO defaults live in src/data/brand.ts and src/data/seo.ts.
# On Vercel, set production values in Project → Settings → Environment Variables.

# ─── Required on Vercel (Production + Preview) ───────────────────────────────
# Your live backend API URL (no trailing slash). Forms and consultation booking
# will not work without this in production.
#
# Example production:
# NEXT_PUBLIC_API_URL=https://api.projonexa.com
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Optional — Google Search Console ────────────────────────────────────────
# HTML tag verification value from Search Console → Settings → Ownership verification
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# ─── Optional — Analytics (enable one or both in production) ─────────────────
# Privacy-friendly analytics:
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=www.projonexa.com
#
# Google Analytics 4 measurement ID:
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
